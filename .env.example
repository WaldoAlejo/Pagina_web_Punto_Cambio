# ── API PostgREST (GCP PostgreSQL) ───────────────────────────────────────────
# URL de tu instancia PostgREST corriendo en GCP
# Ejemplo: http://34.x.x.x:3000  o  https://api.tucdominio.com
VITE_API_URL=http://TU_IP_GCP:3000

# Si configuras JWT en PostgREST, pon aquí el anon key
# VITE_API_ANON_KEY=tu_jwt_anon_key
